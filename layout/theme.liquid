<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#3D2817">

  <title>
    {%- if page_title == shop.name -%}
      {{ shop.name }} — Litière Robot Intelligente pour Chats
    {%- else -%}
      {{ page_title }} — {{ shop.name }}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta name="description" content="PETCARE SMART — Litière robot intelligente, nettoyage automatique 24/7, app connectée. Liberté Sans Effort pour vous et votre chat.">
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:site_name" content="{{ shop.name }}">
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
  {%- endif -%}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Outfit:wght@300;400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Main Stylesheet -->
  {{ 'styles.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="template-{{ template.name }}">
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  {% section 'header' %}

  <main id="main-content">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Floating Add-to-Cart Bar -->
  {%- assign product = all_products['petcare-smart-litiere-robot-intelligente'] -%}
  <div class="floating-atc" role="complementary" aria-label="Achat rapide">
    <div class="floating-atc__inner">
      <div class="floating-atc__info">
        <span class="floating-atc__name">PETCARE SMART</span>
        <span class="floating-atc__price">349,90 €</span>
      </div>
      <a
        href="/cart/add?id={%- if product != blank -%}{{ product.selected_or_first_available_variant.id }}{%- else -%}0{%- endif -%}&quantity=1"
        class="btn btn--primary floating-atc__btn"
        data-add-to-cart
        data-variant-id="{%- if product != blank -%}{{ product.selected_or_first_available_variant.id }}{%- endif -%}"
      >
        Ajouter au panier
      </a>
    </div>
  </div>

  <!-- Scripts -->
  <script src="{{ 'script.js' | asset_url }}" defer></script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
