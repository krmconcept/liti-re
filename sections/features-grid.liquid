<section class="features-section" id="features">
  <div class="container">
    <div class="section-title reveal">
      <span class="section-eyebrow">Fonctionnalités</span>
      <h2>{{ section.settings.title | default: 'Technologie Intelligente' }}</h2>
      <p>{{ section.settings.subtitle | default: 'Chaque détail a été pensé pour vous et votre chat.' }}</p>
    </div>

    <div class="features-grid">
      {%- for block in section.blocks -%}
        {%- assign is_featured = forloop.first -%}
        <div class="feature-card reveal{% if is_featured %} feature-card--featured{% endif %}" {{ block.shopify_attributes }}>
          {%- if is_featured -%}
            <span class="feature-card-badge">Fonctionnalité phare</span>
          {%- endif -%}
          {%- if block.settings.image != blank -%}
            <img
              class="feature-card-img"
              src="{{ block.settings.image | image_url: width: 700 }}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              loading="lazy"
              width="700"
              height="460"
            >
          {%- elsif block.settings.image_filename != blank -%}
            <img
              class="feature-card-img"
              src="{{ block.settings.image_filename | asset_url }}"
              alt="{{ block.settings.title | escape }}"
              loading="lazy"
              width="700"
              height="460"
            >
          {%- endif -%}
          <div class="feature-card-body">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
        </div>
      {%- else -%}
        <!-- Default features using asset images -->
        <div class="feature-card feature-card--featured reveal">
          <span class="feature-card-badge">Fonctionnalité phare</span>
          <img class="feature-card-img" src="{{ 'mechanism.jpg' | asset_url }}" alt="Mécanisme de nettoyage automatique intelligent" loading="lazy" width="700" height="460">
          <div class="feature-card-body">
            <h3>Mécanisme Breveté Sans Chimiques</h3>
            <p>Nettoyage automatique par rotation douce. 100 % sûr pour vos chats, même les plus sensibles. Aucun produit, aucun résidu.</p>
          </div>
        </div>

        <div class="feature-card reveal">
          <img class="feature-card-img" src="{{ 'app-feature.jpg' | asset_url }}" alt="App mobile connectée PETCARE SMART" loading="lazy" width="600" height="400">
          <div class="feature-card-body">
            <h3>App Connectée</h3>
            <p>Suivi santé en temps réel, historique, alertes. Toujours informé, même à distance.</p>
          </div>
        </div>

        <div class="feature-card reveal">
          <img class="feature-card-img" src="{{ 'multi-cat.jpg' | asset_url }}" alt="Parfait pour 3 à 4 chats" loading="lazy" width="600" height="400">
          <div class="feature-card-body">
            <h3>Parfait pour 3–4 Chats</h3>
            <p>Capacité 65 L. Un seul robot remplace 3 litières traditionnelles.</p>
          </div>
        </div>

        <div class="feature-card reveal">
          <img class="feature-card-img" src="{{ 'noise-feature.jpg' | asset_url }}" alt="Silencieux moins de 35 décibels" loading="lazy" width="600" height="400">
          <div class="feature-card-body">
            <h3>Silencieux &lt; 35 dB</h3>
            <p>Moins bruyant qu'une conversation normale. Nettoyage nocturne sans déranger personne.</p>
          </div>
        </div>

        <div class="feature-card reveal">
          <img class="feature-card-img" src="{{ 'app-interface.jpg' | asset_url }}" alt="Interface application mobile" loading="lazy" width="600" height="400">
          <div class="feature-card-body">
            <h3>Design Premium Compact</h3>
            <p>480 × 520 × 505 mm. Élégant, discret, s'intègre dans n'importe quelle pièce.</p>
          </div>
        </div>

        <div class="feature-card reveal">
          <img class="feature-card-img" src="{{ 'space-optimization.jpg' | asset_url }}" alt="Grande capacité 65 litres" loading="lazy" width="600" height="400">
          <div class="feature-card-body">
            <h3>Capacité 65 L</h3>
            <p>15 jours pour 1 chat, 5 jours pour 3–4 chats. Moins de maintenance, plus de liberté.</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Grille de fonctionnalités",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Technologie Intelligente" },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Chaque détail a été pensé pour vous et votre chat." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Fonctionnalité",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "image_filename", "label": "Nom du fichier (assets/)", "info": "Ex: mechanism.jpg" },
        { "type": "text", "id": "title", "label": "Titre", "default": "Fonctionnalité" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Description de la fonctionnalité..." }
      ]
    }
  ],
  "presets": [{ "name": "Grille de fonctionnalités" }]
}
{% endschema %}
