<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <p class="logo">PETCARE SMART</p>
        <p>Litière robot intelligente pour chats. Nettoyage automatique 24/7, app connectée, et suivi santé en temps réel. Liberté Sans Effort.</p>

        <div class="footer-social" aria-label="Réseaux sociaux">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" class="social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- else -%}
            <a href="#" class="social-link" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" class="social-link" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" class="social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.87a8.22 8.22 0 0 0 4.83 1.55V7a4.84 4.84 0 0 1-1.06-.31z"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop column -->
      <div class="footer-col">
        <h4>Boutique</h4>
        <ul>
          <li><a href="/collections/all">Notre Produit</a></li>
          <li><a href="/pages/garantie">Garantie</a></li>
          <li><a href="/pages/livraison">Livraison</a></li>
          <li><a href="/collections/all">Commander</a></li>
        </ul>
      </div>

      <!-- Help column -->
      <div class="footer-col">
        <h4>Aide</h4>
        <ul>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="mailto:{{ settings.contact_email | default: 'contact@petcaresmart.be' }}">Support</a></li>
          <li><a href="/pages/installation">Installation</a></li>
        </ul>
      </div>

      <!-- Legal column -->
      <div class="footer-col">
        <h4>Légal</h4>
        <ul>
          <li><a href="/policies/privacy-policy">Confidentialité</a></li>
          <li><a href="/policies/terms-of-service">CGV</a></li>
          <li><a href="/policies/refund-policy">Retours</a></li>
          <li><a href="/policies/shipping-policy">Livraison</a></li>
        </ul>
      </div>
    </div>

    <!-- Footer bottom bar -->
    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} PETCARE SMART — KRM Concept. Tous droits réservés.
      </p>

      <div class="footer-payments" aria-label="Moyens de paiement acceptés">
        <span class="payment-icon">Visa</span>
        <span class="payment-icon">MC</span>
        <span class="payment-icon">PayPal</span>
        <span class="payment-icon">Klarna</span>
        <span class="payment-icon">Apple Pay</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page",
  "settings": []
}
{% endschema %}
