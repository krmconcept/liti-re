<section class="before-after-section" id="before-after" aria-label="Avant et Après PETCARE SMART">
  <div
    class="before-after-bg"
    style="background-image: url('{{ section.settings.image != blank | image_url: width: 1400 | default: 'before-after.jpg' | asset_url }}');"
    role="img"
    aria-label="Comparaison avant/après : litière traditionnelle vs PETCARE SMART"
  ></div>
  <div class="before-after-overlay"></div>

  <div class="container" style="position:relative;z-index:2;width:100%;">
    <div class="before-after-content">
      <h2>{{ section.settings.heading | default: 'Avant vs Après' }}</h2>
      <p>{{ section.settings.text | default: 'Abandonnez les corvées quotidiennes. Avec PETCARE SMART, chaque utilisation est nettoyée automatiquement. Plus jamais de scooping.' }}</p>
      <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="btn btn-white btn-lg">
        {{ section.settings.cta_text | default: 'Passer à PETCARE SMART' }}
      </a>
    </div>
  </div>
</section>

<style>
  .before-after-section .before-after-bg {
    background-image: url("{{ 'before-after.jpg' | asset_url }}");
  }
</style>

{% schema %}
{
  "name": "Avant / Après",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond (before-after.jpg par défaut)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Avant vs Après"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Abandonnez les corvées quotidiennes. Avec PETCARE SMART, chaque utilisation est nettoyée automatiquement."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton",
      "default": "Passer à PETCARE SMART"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [{ "name": "Avant / Après" }]
}
{% endschema %}
