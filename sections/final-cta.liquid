<section class="final-cta-section" id="commander">
  <div class="container">
    <h2>{{ section.settings.heading | default: 'Prêt à Transformer la Vie de Votre Chat ?' }}</h2>
    <p class="subtitle">{{ section.settings.subheading | default: 'Et la Vôtre.' }}</p>

    <div style="display:flex;flex-direction:column;align-items:center;gap:var(--space-md)">
      <a
        href="{{ section.settings.cta_link | default: '/collections/all' }}"
        class="btn btn-primary btn-xl"
        style="min-width:300px"
      >
        {{ section.settings.cta_text | default: 'Acheter Maintenant' }}
      </a>

      <p class="final-cta-meta">
        {{ section.settings.meta | default: 'Paiement sécurisé • Livraison rapide • Support 24/7' }}
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Final",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titre", "default": "Prêt à Transformer la Vie de Votre Chat ?" },
    { "type": "text", "id": "subheading", "label": "Sous-titre", "default": "Et la Vôtre." },
    { "type": "text", "id": "cta_text", "label": "Texte du bouton", "default": "Acheter Maintenant" },
    { "type": "url", "id": "cta_link", "label": "Lien du bouton" },
    { "type": "text", "id": "meta", "label": "Texte sous le bouton", "default": "Paiement sécurisé • Livraison rapide • Support 24/7" }
  ],
  "presets": [{ "name": "CTA Final" }]
}
{% endschema %}
