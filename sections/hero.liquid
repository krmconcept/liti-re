<section class="hero-section" aria-label="Section hero">
  <div
    class="hero-bg"
    style="background-image: url('{{ 'hero-liberty.jpg' | asset_url }}');"
    role="img"
    aria-label="{{ section.settings.image_alt | default: 'Litière robot PETCARE SMART' }}"
  ></div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    {%- if section.settings.badge != blank -%}
      <span class="hero-badge">{{ section.settings.badge }}</span>
    {%- else -%}
      <span class="hero-badge">✨ Nettoyage Automatique 24/7</span>
    {%- endif -%}

    <h1>{{ section.settings.heading | default: 'Liberté Sans Effort' }}</h1>

    <p>{{ section.settings.subheading | default: 'Litière intelligente pour chats • Nettoyage automatique 24/7' }}</p>

    <div class="hero-actions">
      <a
        href="{{ section.settings.cta_link | default: '/collections/all' }}"
        class="btn btn-primary btn-lg"
      >
        {{ section.settings.cta_text | default: 'Découvrir PETCARE SMART' }}
      </a>
      <a href="#benefits" class="btn btn-white btn-lg">
        En savoir plus
      </a>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <span>Découvrir</span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="6 9 12 15 18 9"/>
    </svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge (texte au-dessus du titre)",
      "default": "✨ Nettoyage Automatique 24/7"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre principal",
      "default": "Liberté Sans Effort"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Litière intelligente pour chats • Nettoyage automatique 24/7"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Texte du bouton principal",
      "default": "Découvrir PETCARE SMART"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton principal"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero (alternative à hero-liberty.jpg)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif de l'image",
      "default": "Litière robot PETCARE SMART"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
