<div class="cart-page">
  <div class="container">
    <h1>Votre Panier</h1>

    {%- if cart.item_count > 0 -%}
      <form action="/cart" method="post" novalidate>
        <div class="cart-layout">
          <!-- Cart items -->
          <div class="cart-items">
            {%- for item in cart.items -%}
              <div class="cart-item">
                <div class="cart-item-img">
                  <a href="{{ item.url }}">
                    <img
                      src="{{ item.image | image_url: width: 200 }}"
                      alt="{{ item.image.alt | default: item.title | escape }}"
                      width="100"
                      height="100"
                      loading="lazy"
                    >
                  </a>
                </div>

                <div>
                  <p class="cart-item-title">
                    <a href="{{ item.url }}">{{ item.product.title }}</a>
                  </p>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <p class="cart-item-price">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  <p class="cart-item-price">{{ item.price | money }} × {{ item.quantity }}</p>

                  <div class="quantity-selector" style="margin-top:0.5rem">
                    <button type="button" class="qty-btn qty-minus" aria-label="Diminuer">−</button>
                    <input
                      type="number"
                      class="qty-input"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="Quantité pour {{ item.title }}"
                    >
                    <button type="button" class="qty-btn qty-plus" aria-label="Augmenter">+</button>
                  </div>
                </div>

                <div style="text-align:right">
                  <p style="font-family:var(--font-heading);font-weight:700;color:var(--brown)">
                    {{ item.line_price | money }}
                  </p>
                  <a
                    href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
                    class="cart-item-remove"
                    aria-label="Supprimer {{ item.title }}"
                  >
                    Supprimer
                  </a>
                </div>
              </div>
            {%- endfor -%}

            <div style="text-align:right;margin-top:var(--space-md)">
              <button type="submit" name="update" class="btn btn-secondary">
                Mettre à jour le panier
              </button>
            </div>
          </div>

          <!-- Cart summary -->
          <div class="cart-summary">
            <h3>Récapitulatif</h3>

            <div class="cart-summary-row">
              <span>Sous-total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary-row">
              <span>Livraison</span>
              <span style="color:var(--green-dark)">Gratuite</span>
            </div>

            <div class="cart-summary-row cart-summary-total">
              <span>Total</span>
              <span>{{ cart.total_price | money }}</span>
            </div>

            <div style="margin-top:var(--space-md)">
              <p style="font-size:0.8125rem;color:var(--text-muted);margin-bottom:var(--space-sm)">
                Taxes incluses. Livraison calculée à la caisse.
              </p>
            </div>

            <a href="/checkout" class="btn btn-primary btn-full btn-lg" style="margin-top:var(--space-md)">
              Passer la commande
            </a>

            <p style="font-size:0.75rem;color:var(--text-muted);text-align:center;margin-top:var(--space-sm)">
              🔒 Paiement sécurisé — SSL 256-bit
            </p>

            <div style="margin-top:var(--space-md);padding-top:var(--space-md);border-top:1px solid rgba(61,40,23,0.1)">
              <p style="font-size:0.8125rem;color:var(--green-dark);font-weight:600;text-align:center">
                ✓ 30 jours satisfait ou remboursé
              </p>
            </div>
          </div>
        </div>
      </form>

    {%- else -%}
      <div style="text-align:center;padding-block:var(--space-xxl)">
        <p style="font-size:3rem;margin-bottom:var(--space-md)">🛒</p>
        <h2 style="color:var(--brown);margin-bottom:var(--space-md)">Votre panier est vide</h2>
        <p style="color:var(--text-muted);margin-bottom:var(--space-lg)">
          Découvrez notre litière robot intelligente.
        </p>
        <a href="/collections/all" class="btn btn-primary btn-lg">
          Voir le produit
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
